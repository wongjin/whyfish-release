{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WhyFish",
  "version": "0.2.1",
  "identifier": "com.whyfish.desktop",
  "build": {
    "frontendDist": "../../../app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WhyFish",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https:; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
